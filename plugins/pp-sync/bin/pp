#!/usr/bin/env bash
# pp — Power Pages CLI dispatcher (NerdyQ pp-sync plugin)
#
# Single-command interface for Power Pages portal sync, solution import/export,
# and permissions audit, backed by a per-project config registry.
#
# See: https://github.com/Nerdy-Q/claude-power-pages-plugins
#
# Quick start:
#   pp setup              # one-time bootstrap (auto-detects projects + PAC profiles)
#   pp list               # list registered projects
#   pp down <project>     # sync down
#   pp up <project>       # sync up (with bulk-upload safety)
#   pp doctor <project>   # health check
#   pp audit <project>    # run permissions audit
#   pp solution-down <project> [solution]    # export solution
#
# Project name resolution:
#   1. Exact match in ~/.config/nq-pp-sync/projects/<name>.conf
#   2. Alias lookup in ~/.config/nq-pp-sync/aliases
#   3. Unique prefix match (e.g. "acm" -> "acme-dev" if no other "acm*")
#   4. Active project (~/.config/nq-pp-sync/active) if no arg passed

# Strict mode is enabled inside main() rather than at the top of the file.
# This lets test_load_project.sh source bin/pp to access load_project()
# without forcing set -e on the test runner's outer shell.

# ===========================================================================
# Paths
# ===========================================================================

PP_CONFIG_DIR="${PP_CONFIG_DIR:-$HOME/.config/nq-pp-sync}"
PP_PROJECTS_DIR="${PP_PROJECTS_DIR:-$PP_CONFIG_DIR/projects}"
PP_ALIASES_FILE="${PP_ALIASES_FILE:-$PP_CONFIG_DIR/aliases}"
PP_ACTIVE_FILE="${PP_ACTIVE_FILE:-$PP_CONFIG_DIR/active}"

# ===========================================================================
# Output helpers
# ===========================================================================

if [ -t 1 ]; then
    BOLD=$'\033[1m'; RED=$'\033[31m'; GRN=$'\033[32m'
    YLW=$'\033[33m'; BLU=$'\033[34m'; RST=$'\033[0m'
else
    BOLD=""; RED=""; GRN=""; YLW=""; BLU=""; RST=""
fi

info()  { printf '%s→%s %s\n' "$BLU" "$RST" "$*"; }
ok()    { printf '%s✓%s %s\n' "$GRN" "$RST" "$*"; }
warn()  { printf '%s⚠%s %s\n' "$YLW" "$RST" "$*" >&2; }
err()   { printf '%s✗%s %s\n' "$RED" "$RST" "$*" >&2; }
die()   { err "$@"; exit 1; }

# Reject identifiers that contain shell metacharacters, whitespace, or
# anything else that would be unsafe to interpolate into bash heredocs,
# regex patterns, or filename components. Used at every registration site
# so that values written into ~/.config/nq-pp-sync/projects/*.conf cannot
# be crafted to inject commands when the conf is later sourced.
validate_identifier() {
    local field="$1" value="$2" pattern="${3:-^[A-Za-z0-9_.-]+\$}"
    if [[ ! "$value" =~ $pattern ]]; then
        die "$field must match $pattern: got '$value'"
    fi
}

# Validate that an issue URL points to the *current* git repository.
# Closes the journal-URL hijacking path: JOURNAL.md is committed and
# shared via PR, so an attacker who lands a PR appending a URL like
# https://github.com/other-org/private-repo/issues/42 could cause the
# next `pp journal note|close` to post (or close) an arbitrary issue
# the maintainer has push access to.
#
# Strategy: enforce a strict URL shape (no unexpected path segments) AND
# require a host+path-prefix match against `gh repo view` / `glab repo
# view`. If the current-repo URL cannot be determined, refuse the action.
#
# Same-repo issue confusion (an attacker swapping issue NUMBER within the
# same repo) is not addressed here — that requires a side-channel state
# file tracking which issue `pp journal open` actually created. Tracked
# as a follow-up in audit umbrella #1.
validate_issue_url_for_current_repo() {
    local url="$1"
    if [[ ! "$url" =~ ^https://(github|gitlab)\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+(/-)?/issues/[0-9]+$ ]]; then
        die "Refusing to operate on issue URL with unexpected shape: $url"
    fi
    local current_repo=""
    case "$url" in
        https://github.com/*)
            command -v gh >/dev/null 2>&1 || die "gh required to validate GitHub issue URL"
            current_repo=$(gh repo view --json url -q .url 2>/dev/null || true)
            ;;
        https://gitlab.com/*)
            command -v glab >/dev/null 2>&1 || die "glab required to validate GitLab issue URL"
            current_repo=$(glab repo view 2>/dev/null | grep -oE 'https://gitlab\.com/[A-Za-z0-9_./-]+' | head -1 || true)
            ;;
    esac
    [ -n "$current_repo" ] || die "Cannot determine current repo to validate issue URL: $url"
    case "$url" in
        "$current_repo"/issues/*|"$current_repo"/-/issues/*) return 0 ;;
    esac
    die "Refusing: issue URL is outside current repo. URL=$url current=$current_repo"
}

# Validate a comma-separated list of solution names and emit the matching
# `SOLUTIONS=("a" "b")` line on stdout. Dies on any invalid entry BEFORE
# any output is produced — callers can capture the result and write it to
# the conf in one shot, avoiding partial writes when validation rejects a
# name mid-list. Empty input emits nothing.
format_solutions_array() {
    local input="$1" s s_trim entries=""
    local IFS=','
    for s in $input; do
        # Pure whitespace trim via parameter expansion. `xargs` was used
        # previously but it does shell-style word-splitting and quote-
        # stripping, which mangles multi-word inputs and produces
        # confusing error messages.
        s_trim="${s#"${s%%[![:space:]]*}"}"
        s_trim="${s_trim%"${s_trim##*[![:space:]]}"}"
        [ -z "$s_trim" ] && continue
        validate_identifier "Solution name" "$s_trim" '^[A-Za-z0-9_.-]+$'
        entries+="\"$s_trim\" "
    done
    [ -n "$entries" ] && printf 'SOLUTIONS=(%s)\n' "$entries"
}

# ===========================================================================
# Project registry helpers
# ===========================================================================

ensure_config_dirs() {
    mkdir -p "$PP_PROJECTS_DIR"
    [ -f "$PP_ALIASES_FILE" ] || touch "$PP_ALIASES_FILE"
}

list_projects() {
    [ -d "$PP_PROJECTS_DIR" ] || return 0
    find "$PP_PROJECTS_DIR" -maxdepth 1 -name "*.conf" -type f 2>/dev/null \
        | sed 's|.*/||; s|\.conf$||' | sort
}

first_alias_target_for() {
    local input="$1" line alias target
    [ -f "$PP_ALIASES_FILE" ] || return 1
    while IFS= read -r line || [ -n "$line" ]; do
        [ -n "$line" ] || continue
        case "$line" in
            \#*) continue ;;
        esac
        alias="${line%%=*}"
        target="${line#*=}"
        [ "$alias" = "$line" ] && continue
        if [ "$alias" = "$input" ]; then
            printf '%s\n' "$target"
            return 0
        fi
    done < "$PP_ALIASES_FILE"
    return 1
}

list_projects_with_prefix() {
    local prefix="$1" project
    while IFS= read -r project; do
        [ -n "$project" ] || continue
        case "$project" in
            "$prefix"*) printf '%s\n' "$project" ;;
        esac
    done < <(list_projects)
}

# Resolve a user-supplied name to a real project name.
# Honors:  exact match > alias > unique prefix > active
resolve_project() {
    local input="${1:-}"
    if [ -z "$input" ]; then
        if [ -f "$PP_ACTIVE_FILE" ]; then
            cat "$PP_ACTIVE_FILE"
            return 0
        fi
        return 1
    fi

    # Exact match
    if [ -f "$PP_PROJECTS_DIR/$input.conf" ]; then
        echo "$input"
        return 0
    fi

    # Alias lookup — file format: "alias=target" one per line
    local target
    target=$(first_alias_target_for "$input" || true)
    if [ -n "$target" ] && [ -f "$PP_PROJECTS_DIR/$target.conf" ]; then
        echo "$target"
        return 0
    fi

    # Unique prefix
    local matches
    matches=$(list_projects_with_prefix "$input")
    local count
    count=$(printf '%s\n' "$matches" | grep -c . || true)
    if [ "$count" = "1" ]; then
        echo "$matches"
        return 0
    elif [ "$count" -gt 1 ]; then
        err "Ambiguous project name '$input'. Matches:"
        printf '  %s\n' $matches >&2
        return 2
    fi

    return 1
}

# Read a project's config file into the current shell WITHOUT sourcing it.
#
# The conf format is intentionally a subset of bash that this parser can
# handle directly: simple `KEY="value"` lines plus an optional
# `SOLUTIONS=("Foo" "Bar")` array form. Keys outside the allowlist are
# warned-and-skipped; lines that don't match the expected pattern are also
# skipped with a warning. No shell evaluation occurs at any point.
#
# Why not source: the conf lives in ~/.config/nq-pp-sync/projects/ and
# encodes paths, URLs, and identifiers that may have been hand-edited or
# pre-existed before this version of pp shipped. Sourcing turned every
# field into an arbitrary-code-execution sink (CVE-class issue #1 from
# the 2026-04-29 audit). This parser eliminates that surface.
#
# Sets: NAME REPO SITE_DIR PROFILE WEBSITE_ID ENV_URL MODEL_VERSION
#       SOLUTIONS BRANCH SCHEMA_DIR BOARD_URL BOARD_SYSTEM AI_ATTR TAGS
load_project() {
    local name="$1"
    local conf="$PP_PROJECTS_DIR/$name.conf"
    [ -f "$conf" ] || die "No config file: $conf"

    # Reset variables before reading
    NAME=""; REPO=""; SITE_DIR=""; PROFILE=""; WEBSITE_ID=""
    ENV_URL=""; MODEL_VERSION="2"; BRANCH=""; SCHEMA_DIR="dataverse-schema"
    BOARD_URL=""; BOARD_SYSTEM="auto"; AI_ATTR="yes"
    TAGS=""
    SOLUTIONS=()

    local known_keys=" NAME REPO SITE_DIR PROFILE WEBSITE_ID ENV_URL MODEL_VERSION BRANCH SCHEMA_DIR BOARD_URL BOARD_SYSTEM AI_ATTR TAGS "
    local lineno=0 line key value
    while IFS= read -r line || [ -n "$line" ]; do
        lineno=$((lineno + 1))
        # Skip blanks and comments
        case "$line" in
            ''|\#*) continue ;;
        esac

        # SOLUTIONS=("a" "b") — special-case the array form. Extract each
        # quoted token without invoking the shell on the contents. The
        # capture is greedy so that values containing `)` (e.g. an
        # injection payload like `$(rm -rf /)` written by an attacker
        # trying to exploit the pre-v2.0.0 source-evaluated loader) are
        # preserved as literal strings rather than rejected at parse
        # time. The inner extraction loop matches each "..." token, and
        # validation at write-time (format_solutions_array) blocks shell
        # metacharacters from being added to a conf in the first place.
        if [[ "$line" =~ ^SOLUTIONS=\((.*)\)[[:space:]]*$ ]]; then
            SOLUTIONS=()
            local rest="${BASH_REMATCH[1]}"
            while [[ "$rest" =~ \"([^\"]*)\" ]]; do
                SOLUTIONS+=( "${BASH_REMATCH[1]}" )
                rest="${rest#*\"${BASH_REMATCH[1]}\"}"
            done
            continue
        fi

        # Standard KEY="value" form. Value cannot contain unescaped double
        # quotes (we don't support backslash escaping — keep the format
        # boring on purpose).
        if [[ "$line" =~ ^([A-Z_]+)=\"([^\"]*)\"[[:space:]]*$ ]]; then
            key="${BASH_REMATCH[1]}"
            value="${BASH_REMATCH[2]}"
            if [[ " $known_keys " != *" $key "* ]]; then
                warn "$conf:$lineno: unknown key '$key' (skipped)"
                continue
            fi
            # Reject control characters and CR/LF in values.
            if [[ "$value" == *$'\n'* ]] || [[ "$value" == *$'\r'* ]]; then
                die "$conf:$lineno: control character in value for $key"
            fi
            # printf -v assigns by name without eval. Safe because key has
            # been allowlisted against the fixed list above.
            printf -v "$key" '%s' "$value"
            continue
        fi

        warn "$conf:$lineno: unparsable line (skipped): $line"
    done < "$conf"

    # Required-field validation
    [ -n "$NAME" ] || die "$conf: missing NAME"
    [ -n "$REPO" ] || die "$conf: missing REPO"
    [ -n "$SITE_DIR" ] || die "$conf: missing SITE_DIR"
    [ -n "$PROFILE" ] || die "$conf: missing PROFILE"

    # Re-apply defaults for keys-with-defaults that the conf may have set
    # to an empty string. The parser doesn't distinguish "key omitted" from
    # `KEY=""` — both produce the empty string — so we re-default after
    # parsing rather than during the per-line assignment.
    [ -n "$MODEL_VERSION" ] || MODEL_VERSION="2"
    [ -n "$SCHEMA_DIR" ] || SCHEMA_DIR="dataverse-schema"
    [ -n "$BOARD_SYSTEM" ] || BOARD_SYSTEM="auto"
    [ -n "$AI_ATTR" ] || AI_ATTR="yes"

    # Expand ~ in REPO via bash parameter expansion (no shell evaluation)
    REPO="${REPO/#~/$HOME}"

    # Session safety for journaling only. Do not block non-interactive pp flows.
    local board_verify_key=""
    if [ -n "$BOARD_URL" ]; then
        board_verify_key="${NAME}|${BOARD_SYSTEM}|${BOARD_URL}|${AI_ATTR}"
    fi
    if [ -n "$BOARD_URL" ] && [ "${PP_REQUIRE_BOARD_CONFIRM:-0}" = "1" ] \
       && [ "${PP_SESSION_VERIFIED_BOARD:-}" != "$board_verify_key" ] && [ -t 0 ] && [ -t 1 ]; then
        echo
        warn "Journaling is active for project: ${BOLD}$NAME${RST}"
        echo "  Target Board: $BOARD_URL"
        echo "  System:       $BOARD_SYSTEM"
        echo "  AI Tagging:   $AI_ATTR"
        echo
        local ans
        read -r -p "Continue with this board mapping? [Y/n]: " ans
        if [ "$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')" = "n" ]; then
            die "Aborted. Check $conf to correct mapping."
        fi
        export PP_SESSION_VERIFIED_BOARD="$board_verify_key"
    fi
}

read_aliases_for() {
    local target="$1"
    [ -f "$PP_ALIASES_FILE" ] || return 0
    grep -E "=${target}\$" "$PP_ALIASES_FILE" 2>/dev/null | cut -d= -f1 || true
}

# ===========================================================================
# Pre-flight helpers (shared by down/up/etc.)
# ===========================================================================

cd_repo_root() {
    local repo="$1"
    [ -d "$repo" ] || die "Project repo not found: $repo"
    cd "$repo" || die "Cannot cd to $repo"
    # If this is a git repo, snap to its top. Otherwise stay where we
    # are — repos managed by pp don't strictly require git (e.g. doctor
    # against a fresh checkout, or a tarball-shipped portal source).
    local top
    top=$(git rev-parse --show-toplevel 2>/dev/null || true)
    if [ -n "$top" ]; then
        cd "$top" || die "Cannot cd to git top: $top"
    fi
    return 0
}

confirm_pac_profile() {
    local profile="$1"
    if ! pac auth list 2>/dev/null | grep -qE "^\\[[0-9]+\\][[:space:]]*\\*?[[:space:]]+UNIVERSAL[[:space:]]+${profile}\\b"; then
        die "PAC profile '$profile' is not registered. Run: pac auth create --name $profile --environment <env-url>"
    fi
    pac auth select --name "$profile" >/dev/null 2>&1 \
        || die "Failed to select PAC profile '$profile'"
    local actual_url
    actual_url=$(pac org who 2>&1 | awk -F': ' '/Environment Url/{print $2; exit}')
    [ -n "$actual_url" ] || die "pac org who returned no env URL — profile may need re-auth"
    info "Active env: $actual_url"
    echo "$actual_url"
}

confirm_action() {
    local prompt="$1"
    local ans
    read -r -p "$prompt [y/N] " ans
    [ "$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')" = "y" ] || { info "Aborted."; exit 0; }
}

# ===========================================================================
# Subcommand: setup
# ===========================================================================

cmd_setup() {
    ensure_config_dirs
    info "${BOLD}pp-sync setup${RST}"
    echo
    echo "Config dir: $PP_CONFIG_DIR"
    echo

    # Existing projects
    local existing
    existing=$(list_projects)
    if [ -n "$existing" ]; then
        warn "Existing projects: $(echo "$existing" | tr '\n' ' ')"
        confirm_action "Continue and add more?"
    fi

    # Detect PAC profiles
    info "Detecting PAC auth profiles…"
    if ! command -v pac >/dev/null 2>&1; then
        die "pac CLI not found. Install Power Platform CLI first."
    fi
    local pac_output
    pac_output=$(pac auth list 2>/dev/null) || die "pac auth list failed"
    echo "$pac_output" | grep -E '^\[[0-9]+\]' | head -10
    echo

    # Detect candidate site folders
    info "Scanning $HOME for Power Pages site folders…"
    local candidates
    candidates=$(find "$HOME/Projects" -maxdepth 6 -type d -name "*---*" 2>/dev/null | while read -r d; do
        if [ -f "$d/website.yml" ] && [ -d "$d/web-pages" ]; then
            echo "$d"
        fi
    done | head -20)

    if [ -z "$candidates" ]; then
        warn "No site folders auto-detected under $HOME/Projects"
        info "You can register projects manually: pp project add <name>"
        return 0
    fi

    echo "Found:"
    # Quote $candidates so paths with spaces stay one-per-line. The
    # find pipeline produces newline-separated entries; bash word-
    # splitting on unquoted $candidates would mis-print such paths.
    printf '%s\n' "$candidates" | sed 's/^/  /'
    echo
    confirm_action "Walk through registering each candidate?"

    while IFS= read -r candidate; do
        [ -z "$candidate" ] && continue
        echo
        echo "${BOLD}Candidate:${RST} $candidate"
        local default_name suggested_alias
        default_name=$(basename "$(dirname "$candidate")" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g; s/--*/-/g; s/^-//; s/-$//')
        # Special-case: if the parent is "pages" (multi-division portfolios), use the grandparent's parent
        if [ "$default_name" = "pages" ]; then
            default_name=$(basename "$(dirname "$(dirname "$candidate")")" | tr '[:upper:]' '[:lower:]')
        fi

        local name
        read -r -p "Project name [$default_name]: " name
        name="${name:-$default_name}"
        validate_identifier "Project name" "$name" '^[A-Za-z0-9_-]+$'
        if [ -f "$PP_PROJECTS_DIR/$name.conf" ]; then
            warn "$name already registered — skipping"
            continue
        fi

        # Suggest an alias (first 4-5 chars of the slug)
        suggested_alias=$(echo "$name" | cut -c1-5)
        local alias_input
        read -r -p "Shorthand alias [$suggested_alias, or 'none']: " alias_input
        alias_input="${alias_input:-$suggested_alias}"
        if [ "$alias_input" != "none" ]; then
            validate_identifier "Alias" "$alias_input" '^[A-Za-z0-9_-]+$'
        fi

        # Auto-fill what we can
        local repo site_rel pac_profile env_url
        repo=$(git -C "$candidate" rev-parse --show-toplevel 2>/dev/null || echo "$(dirname "$candidate")")
        site_rel=$(realpath --relative-to="$repo" "$candidate" 2>/dev/null || echo "$candidate")
        # Mac realpath fallback
        if [ -z "$site_rel" ] || [ "$site_rel" = "$candidate" ]; then
            site_rel="${candidate#$repo/}"
        fi

        echo
        echo "Auto-detected:"
        echo "  Repo:       $repo"
        echo "  Site dir:   $site_rel"
        echo

        # Profile selection
        echo "PAC profiles available:"
        echo "$pac_output" | grep -E '^\[[0-9]+\]' | awk '{print "  " $0}' | head
        echo
        read -r -p "PAC profile name (exact, from list): " pac_profile
        [ -z "$pac_profile" ] && { warn "Skipping (no profile given)"; continue; }
        validate_identifier "PAC profile" "$pac_profile" '^[A-Za-z0-9_.-]+$'

        # Get env URL for that profile
        if pac auth select --name "$pac_profile" >/dev/null 2>&1; then
            env_url=$(pac org who 2>&1 | awk -F': ' '/Environment Url/{print $2; exit}')
        fi

        # Optional website id
        local website_id
        read -r -p "Website ID (from 'pac paportal list', blank to skip for now): " website_id

        # Optional solution names
        local solutions
        read -r -p "Solution unique names (comma-separated, blank to skip): " solutions

        # Optional branch
        local branch
        read -r -p "Default branch (blank for any): " branch

        # Journaling and Project Boards
        local board_url board_system ai_attr auto_journal
        echo
        info "--- Journaling & Project Boards ---"
        read -r -p "Enable automated journaling for this project? [Y/n]: " auto_journal
        auto_journal="${auto_journal:-y}"
        if [ "$(printf '%s' "$auto_journal" | tr '[:upper:]' '[:lower:]')" = "y" ]; then
            read -r -p "Project board system (github/gitlab/none) [auto]: " board_system
            board_system="${board_system:-auto}"
            read -r -p "Project board URL/ID (blank to skip): " board_url
            read -r -p "Explicitly tag AI-assisted notes? [Y/n]: " ai_attr
            ai_attr="${ai_attr:-y}"
        fi

        # Validate solutions BEFORE creating the conf so registration is
        # atomic: a bad solution name aborts before any file is written.
        local solutions_block=""
        if [ -n "$solutions" ]; then
            solutions_block=$(format_solutions_array "$solutions")
        fi

        # Write the conf
        cat > "$PP_PROJECTS_DIR/$name.conf" <<EOF
# $name — auto-generated by 'pp setup'
NAME="$name"
REPO="$repo"
SITE_DIR="$site_rel"
PROFILE="$pac_profile"
WEBSITE_ID="$website_id"
ENV_URL="$env_url"
MODEL_VERSION="2"
SCHEMA_DIR="dataverse-schema"
BRANCH="$branch"
BOARD_URL="$board_url"
BOARD_SYSTEM="$board_system"
AI_ATTR="$ai_attr"
TAGS=""
EOF
        [ -n "$solutions_block" ] && printf '%s' "$solutions_block" >> "$PP_PROJECTS_DIR/$name.conf"

        ok "Registered $name"

        # Alias
        if [ "$alias_input" != "none" ] && [ "$alias_input" != "$name" ]; then
            if grep -qE "^${alias_input}=" "$PP_ALIASES_FILE" 2>/dev/null; then
                warn "Alias '$alias_input' already in use; skipping"
            else
                echo "${alias_input}=${name}" >> "$PP_ALIASES_FILE"
                ok "Alias: pp <op> $alias_input"
            fi
        fi

    done <<< "$candidates"

    echo
    ok "Setup complete."
    info "Try: pp list"
    info "Or:  pp doctor <project-or-alias>"
}

# ===========================================================================
# Subcommand: list
# ===========================================================================

cmd_list() {
    ensure_config_dirs
    local projects
    projects=$(list_projects)
    if [ -z "$projects" ]; then
        warn "No projects registered. Run: pp setup"
        return 0
    fi

    printf '%-25s %-30s %s\n' "PROJECT" "ALIASES" "ENVIRONMENT"
    printf '%-25s %-30s %s\n' "-------" "-------" "-----------"
    while IFS= read -r p; do
        [ -z "$p" ] && continue
        load_project "$p"
        local aliases
        aliases=$(read_aliases_for "$p" | tr '\n' ',' | sed 's/,$//')
        printf '%-25s %-30s %s\n' "$p" "${aliases:--}" "${ENV_URL:--}"
    done <<< "$projects"

    if [ -f "$PP_ACTIVE_FILE" ]; then
        echo
        info "Active: $(cat "$PP_ACTIVE_FILE")"
    fi
}

# ===========================================================================
# Subcommand: show
# ===========================================================================

cmd_show() {
    local input="${1:-}"
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"
    local aliases
    aliases=$(read_aliases_for "$name" | tr '\n' ',' | sed 's/,$//')

    cat <<EOF
${BOLD}$NAME${RST}  ($name)
  Aliases:        ${aliases:-(none)}
  Repo:           $REPO
  Site dir:       $SITE_DIR
  PAC profile:    $PROFILE
  Website ID:     ${WEBSITE_ID:-(not set)}
  Env URL:        ${ENV_URL:-(not set)}
  Model version:  $MODEL_VERSION
  Schema dir:     $SCHEMA_DIR
  Default branch: ${BRANCH:-(any)}
  Solutions:      ${SOLUTIONS[*]:-(none)}
  Tags:           ${TAGS:-(none)}
  Config file:    $PP_PROJECTS_DIR/$name.conf
EOF
}

# ===========================================================================
# Subcommand: switch / use
# ===========================================================================

cmd_switch() {
    ensure_config_dirs
    local input="${1:-}"
    [ -z "$input" ] && die "Usage: pp switch <project>"
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    echo "$name" > "$PP_ACTIVE_FILE"
    load_project "$name"
    pac auth select --name "$PROFILE" >/dev/null 2>&1 \
        && ok "PAC profile switched to $PROFILE" \
        || warn "PAC profile select failed (run 'pac auth list' to check)"
    ok "Active project: $name"
}

# ===========================================================================
# Subcommand: status
# ===========================================================================

cmd_status() {
    if [ ! -f "$PP_ACTIVE_FILE" ]; then
        info "No active project. Use: pp switch <project>"
        return 0
    fi
    local name
    name=$(cat "$PP_ACTIVE_FILE")
    load_project "$name"
    info "Active project: ${BOLD}$name${RST}"
    echo "  Repo:       $REPO"
    echo "  Site dir:   $SITE_DIR"
    echo "  PAC profile: $PROFILE"
    if pac auth select --name "$PROFILE" >/dev/null 2>&1; then
        local actual
        actual=$(pac org who 2>&1 | awk -F': ' '/Environment Url/{print $2; exit}')
        echo "  Live env:   ${actual:-(unreachable)}"
    fi
}

# ===========================================================================
# Subcommand: down (sync portal down)
# ===========================================================================

cmd_down() {
    local input="${1:-}"
    local clean=1
    shift || true
    for arg in "$@"; do
        case "$arg" in
            --no-clean) clean=0 ;;
            *) die "Unknown arg: $arg" ;;
        esac
    done

    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"

    info "${BOLD}Sync down: $name${RST}"
    cd_repo_root "$REPO"
    confirm_pac_profile "$PROFILE" >/dev/null

    [ -n "$WEBSITE_ID" ] || die "WEBSITE_ID not set in $name.conf — run 'pac paportal list' to find it"

    if [ -n "$BRANCH" ]; then
        local current
        current=$(git branch --show-current 2>/dev/null || true)
        [ -n "$current" ] && [ "$current" != "$BRANCH" ] \
            && warn "Current branch '$current' != configured '$BRANCH'"
    fi

    if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
        warn "Uncommitted changes in working tree — download may overwrite"
        confirm_action "Continue?"
    fi

    confirm_action "Download into $SITE_DIR ?"

    info "Downloading…"
    pac paportal download --path . --webSiteId "$WEBSITE_ID" --modelVersion "$MODEL_VERSION" || die "Download failed"

    if [ "$clean" = "1" ]; then
        info "Cleaning known noise…"
        git checkout HEAD -- .portalconfig/ 2>/dev/null || true
        if [ -d "$SITE_DIR" ]; then
            if sed --version >/dev/null 2>&1; then
                find "$SITE_DIR" -name "*.webpage.copy.html" -exec sed -i -e 's/[[:space:]]*$//' {} +
            else
                find "$SITE_DIR" -name "*.webpage.copy.html" -exec sed -i '' -e 's/[[:space:]]*$//' {} +
            fi
        fi
    fi

    local total
    # `|| echo 0` guards against `git status` exiting non-zero (e.g. run
    # from outside a git tree); pipefail would otherwise abort cmd_up.
    total=$(git status -s 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    echo
    info "Files changed: $total"
    git status -s 2>/dev/null | head -30 || true
    ok "Done. Review diffs and commit when ready."
}

# ===========================================================================
# Subcommand: up (sync portal up)
# ===========================================================================

cmd_up() {
    local input="${1:-}"
    local validate_only=0 force_bulk=0 bulk_threshold=50
    shift || true
    for arg in "$@"; do
        case "$arg" in
            --validate-only) validate_only=1 ;;
            --force-bulk) force_bulk=1 ;;
            --bulk-threshold=*) bulk_threshold="${arg#*=}" ;;
            *) die "Unknown arg: $arg" ;;
        esac
    done

    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"

    info "${BOLD}Sync up: $name${RST}"
    cd_repo_root "$REPO"
    local actual_env
    actual_env=$(confirm_pac_profile "$PROFILE")

    case "$actual_env" in
        *prod*)
            warn "${BOLD}PRODUCTION ENVIRONMENT${RST}"
            local ans
            read -r -p "Type the project name '$name' to confirm prod upload: " ans
            [ "$ans" = "$name" ] || die "Aborted (confirm string mismatch)."
            ;;
    esac

    local tracked untracked changed
    tracked=$(git diff --name-only HEAD -- "$SITE_DIR" 2>/dev/null || true)
    untracked=$(git ls-files --others --exclude-standard -- "$SITE_DIR" 2>/dev/null || true)
    changed=$(printf '%s\n%s\n' "$tracked" "$untracked" | grep -v '^$' | sort -u | wc -l | tr -d ' ' || echo 0)
    info "Estimated changed files: $changed"

    if [ "$changed" -gt "$bulk_threshold" ] && [ "$force_bulk" = "0" ]; then
        warn "Bulk upload risk ($changed > $bulk_threshold) — portal cache may hang."
        info "Recommend incremental upload or --validate-only first."
        confirm_action "Continue with bulk upload?"
    fi

    if [ "$validate_only" = "1" ]; then
        info "Validating only (no upload)…"
        pac paportal upload --path . --modelVersion "$MODEL_VERSION" --validateBeforeUpload
    else
        info "Uploading…"
        pac paportal upload --path . --modelVersion "$MODEL_VERSION" || die "Upload failed"

        # Smoke-test the portal
        local portal_url
        portal_url=$(echo "$actual_env" | sed 's|crm\.dynamics\.com|powerappsportals.com|; s|crm9\.dynamics\.com|powerappsportals.us|')
        if [ -n "$portal_url" ]; then
            local status
            status=$(curl -sI -o /dev/null -w "%{http_code}" --max-time 30 "$portal_url" 2>/dev/null || echo 000)
            case "$status" in
                200) ok "Portal returns 200 — looks healthy" ;;
                503) warn "503 (cache rebuilding) — wait 30-60s and retry" ;;
                000) warn "Timeout — portal may be hung; check Admin Center" ;;
                *) warn "HTTP $status — investigate" ;;
            esac
        fi
    fi
    ok "Done."
}

# ===========================================================================
# Subcommand: diff (preview what `pp up` would push)
# ===========================================================================

cmd_diff() {
    local input="${1:-}"
    local show_diff=0 names_only=0 bulk_threshold=50
    shift || true
    for arg in "$@"; do
        case "$arg" in
            --diff) show_diff=1 ;;
            --names-only) names_only=1 ;;
            --bulk-threshold=*) bulk_threshold="${arg#*=}" ;;
            *) die "Unknown arg: $arg" ;;
        esac
    done

    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"

    cd_repo_root "$REPO"

    # Collect changed (tracked) + untracked files scoped to SITE_DIR
    local tracked untracked all_changes
    tracked=$(git diff --name-only HEAD -- "$SITE_DIR" 2>/dev/null || true)
    untracked=$(git ls-files --others --exclude-standard -- "$SITE_DIR" 2>/dev/null || true)
    all_changes=$(printf '%s\n%s\n' "$tracked" "$untracked" | grep -v '^$' | sort -u || true)

    # --names-only mode: bare list, skip everything else
    if [ "$names_only" = "1" ]; then
        [ -n "$all_changes" ] && printf '%s\n' "$all_changes"
        return 0
    fi

    # Header — try to read live env via confirm_pac_profile if PAC is available;
    # otherwise fall back to ENV_URL from conf.
    info "${BOLD}Diff preview: $name${RST}"
    echo "  Site dir:   $SITE_DIR"
    local actual_env=""
    if command -v pac >/dev/null 2>&1 \
        && pac auth list 2>/dev/null | grep -qE "UNIVERSAL[[:space:]]+${PROFILE}\\b"; then
        actual_env=$(confirm_pac_profile "$PROFILE" 2>/dev/null || true)
    fi
    if [ -z "$actual_env" ]; then
        actual_env="${ENV_URL:-(unknown — pac profile not active)}"
        echo "  Env (conf): $actual_env"
    fi
    echo

    if [ -z "$all_changes" ]; then
        ok "No changes vs HEAD in $SITE_DIR — nothing to upload."
        return 0
    fi

    # Categorize. Each file lands in exactly one bucket (first match wins).
    local cat_liquid="" cat_js="" cat_css="" cat_metadata=""
    local cat_perms="" cat_settings="" cat_markers=""
    local cat_forms="" cat_lists="" cat_other=""

    while IFS= read -r f; do
        [ -z "$f" ] && continue
        case "$f" in
            *.webpage.copy.html|*.webpage.summary.html|*.webtemplate.source.html|*.contentsnippet.value.html)
                cat_liquid+="$f"$'\n' ;;
            *.webpage.custom_javascript.js)
                cat_js+="$f"$'\n' ;;
            *.webpage.custom_css.css)
                cat_css+="$f"$'\n' ;;
            *.webfile.yml)
                # Web files — can be JS or CSS payloads. Peek at the sibling file
                # extension if we can; otherwise classify generically.
                local sibling_dir sibling_base
                sibling_dir=$(dirname "$f")
                sibling_base=$(basename "$f" .webfile.yml)
                if compgen -G "$sibling_dir/$sibling_base.js" >/dev/null 2>&1; then
                    cat_js+="$f"$'\n'
                elif compgen -G "$sibling_dir/$sibling_base.css" >/dev/null 2>&1; then
                    cat_css+="$f"$'\n'
                else
                    cat_other+="$f"$'\n'
                fi
                ;;
            *.tablepermission.yml|*.webrole.yml)
                cat_perms+="$f"$'\n' ;;
            *sitesetting.yml|*/site-settings/*)
                cat_settings+="$f"$'\n' ;;
            *sitemarker.yml|*/sitemarkers/*)
                cat_markers+="$f"$'\n' ;;
            */basic-forms/*|*/advanced-forms/*)
                cat_forms+="$f"$'\n' ;;
            */entity-lists/*)
                cat_lists+="$f"$'\n' ;;
            *.webpage.yml|*.webtemplate.yml|*.contentsnippet.yml|*.yml)
                cat_metadata+="$f"$'\n' ;;
            *)
                cat_other+="$f"$'\n' ;;
        esac
    done <<< "$all_changes"

    # Print a category section if non-empty.
    print_category() {
        local label="$1" body="$2"
        [ -z "$body" ] && return 0
        local count
        count=$(printf '%s' "$body" | grep -c . || echo 0)
        echo "${BOLD}$label${RST}  ($count)"
        printf '%s' "$body" | sed 's/^/  /'
        echo
    }

    print_category "Liquid + HTML pages"    "$cat_liquid"
    print_category "Custom JS"              "$cat_js"
    print_category "Custom CSS"             "$cat_css"
    print_category "Config metadata"        "$cat_metadata"
    print_category "Permissions"            "$cat_perms"
    print_category "Site settings"          "$cat_settings"
    print_category "Sitemarkers"            "$cat_markers"
    print_category "Forms"                  "$cat_forms"
    print_category "Lists"                  "$cat_lists"
    print_category "Other"                  "$cat_other"

    # Summary
    local total
    total=$(printf '%s\n' "$all_changes" | grep -c . || true)
    echo "${BOLD}Total changed files:${RST} $total"

    # Bulk-upload risk warning — same threshold and intent as pp up
    if [ "$total" -gt "$bulk_threshold" ]; then
        echo
        warn "Bulk upload risk ($total > $bulk_threshold) — portal cache may hang."
        info "Recommend incremental upload or --validate-only first."
    fi

    # Optional: line-level deltas via git diff --stat
    if [ "$show_diff" = "1" ]; then
        echo
        echo "${BOLD}## Line-level deltas (tracked changes only)${RST}"
        git diff --stat HEAD -- "$SITE_DIR" || true
    fi

    # Next steps
    echo
    info "Next: ${BOLD}pp up $name${RST} would push these files via 'pac paportal upload'."
    info "Validate first with: ${BOLD}pp up $name --validate-only${RST}"
}

# ===========================================================================
# Subcommand: doctor
# ===========================================================================

cmd_doctor() {
    local input="${1:-}"
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"

    info "${BOLD}Doctor: $name${RST}"
    cd_repo_root "$REPO"

    echo
    echo "${BOLD}## Tooling${RST}"
    for tool in pac git python3 dotnet curl; do
        if command -v "$tool" >/dev/null 2>&1; then
            ok "$tool present"
        else
            warn "$tool MISSING"
        fi
    done

    echo
    echo "${BOLD}## PAC auth${RST}"
    if pac auth list 2>/dev/null | grep -qE "UNIVERSAL[[:space:]]+${PROFILE}\\b"; then
        ok "Profile $PROFILE registered"
        if pac auth select --name "$PROFILE" >/dev/null 2>&1; then
            local actual
            actual=$(pac org who 2>&1 | awk -F': ' '/Environment Url/{print $2; exit}')
            if [ -n "$actual" ]; then
                ok "Connected: $actual"
                [ -n "$ENV_URL" ] && [ "$actual" != "$ENV_URL" ] \
                    && warn "Configured env $ENV_URL doesn't match live $actual"
            else
                warn "pac org who returned no URL — re-auth needed"
            fi
        fi
    else
        err "Profile $PROFILE not registered"
    fi

    echo
    echo "${BOLD}## Repo${RST}"
    [ -d "$SITE_DIR" ] && ok "Site folder $SITE_DIR exists" || err "Site folder $SITE_DIR MISSING"
    [ -f "$SITE_DIR/website.yml" ] && ok "website.yml present" || err "website.yml MISSING"

    local dirty branch
    dirty=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    branch=$(git branch --show-current 2>/dev/null || echo "(none)")
    echo "  Branch:           $branch"
    echo "  Dirty files:      $dirty"
    if [ "$dirty" -gt 50 ]; then
        warn "High dirty count — possibly PAC noise. Try: pp down $name"
    fi

    echo
    echo "${BOLD}## Site content counts${RST}"
    # `|| echo 0` guards each counter so that a missing subdir or a
    # `find` quirk doesn't trip pipefail and abort doctor mid-report.
    echo "  Web pages:        $(find "$SITE_DIR/web-pages" -name "*.webpage.yml" 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    echo "  Web templates:    $(find "$SITE_DIR/web-templates" -name "*.webtemplate.source.html" 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    echo "  Content snippets: $(find "$SITE_DIR/content-snippets" -name "*.contentsnippet.value.html" 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    echo "  Table perms:      $(find "$SITE_DIR/table-permissions" -name "*.tablepermission.yml" 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    echo "  Custom JS files:  $(find "$SITE_DIR/web-pages" "$SITE_DIR/web-files" -name "*.js" 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    echo
    ok "Done."
}

# ===========================================================================
# Subcommand: solution-down / solution-up
# ===========================================================================

cmd_solution_down() {
    local input="${1:-}"
    local solution="${2:-}"
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"

    # Pick the solution
    if [ -z "$solution" ]; then
        if [ "${#SOLUTIONS[@]}" -eq 0 ]; then
            die "No solutions configured for $name. Pass one explicitly: pp solution-down $name <SolutionName>"
        elif [ "${#SOLUTIONS[@]}" -eq 1 ]; then
            solution="${SOLUTIONS[0]}"
            info "Using solution: $solution"
        else
            echo "Multiple solutions configured for $name:"
            local i=1
            for s in "${SOLUTIONS[@]}"; do
                echo "  $i) $s"
                i=$((i+1))
            done
            local pick
            read -r -p "Pick number or name: " pick
            if [[ "$pick" =~ ^[0-9]+$ ]]; then
                if [ "$pick" -lt 1 ] || [ "$pick" -gt "${#SOLUTIONS[@]}" ]; then
                    die "Pick must be between 1 and ${#SOLUTIONS[@]}: got '$pick'"
                fi
                solution="${SOLUTIONS[$((pick-1))]}"
            else
                solution="$pick"
            fi
        fi
    fi

    info "${BOLD}Solution down: $name / $solution${RST}"
    cd_repo_root "$REPO"
    confirm_pac_profile "$PROFILE" >/dev/null

    mkdir -p "$SCHEMA_DIR"
    local zipfile="$SCHEMA_DIR/${solution}.zip"
    local unpack_dir="$SCHEMA_DIR/$solution"

    confirm_action "Export solution '$solution'?"

    info "Exporting (may take 60-120s)…"
    pac solution export --name "$solution" --path "$zipfile" --managed false || die "Export failed"
    [ -f "$zipfile" ] || die "No zipfile produced"

    info "Unpacking to $unpack_dir"
    rm -rf "$unpack_dir.new"
    pac solution unpack --zipfile "$zipfile" --folder "$unpack_dir.new" --packagetype Unmanaged || die "Unpack failed"

    if [ -d "$unpack_dir" ]; then
        rm -rf "$unpack_dir.bak"
        mv "$unpack_dir" "$unpack_dir.bak"
    fi
    # Chain rather than separate statements: if the second mv fails, keep
    # the .bak copy so the user has not lost their previous unpacked schema.
    if mv "$unpack_dir.new" "$unpack_dir"; then
        rm -rf "$unpack_dir.bak"
    else
        warn "mv to $unpack_dir failed; previous copy preserved at $unpack_dir.bak"
        die "Solution unpack swap failed"
    fi
    rm -f "$zipfile"

    local entity_count
    entity_count=$(find "$unpack_dir/Entities" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    ok "Done. Entities unpacked: $entity_count"
    git status -s "$SCHEMA_DIR" | head -10
}

cmd_solution_up() {
    local input="${1:-}"
    local solution="${2:-}"
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"

    # Pick solution (same logic as solution-down)
    if [ -z "$solution" ]; then
        if [ "${#SOLUTIONS[@]}" -eq 0 ]; then
            die "No solutions configured for $name."
        elif [ "${#SOLUTIONS[@]}" -eq 1 ]; then
            solution="${SOLUTIONS[0]}"
        else
            echo "Multiple solutions:"
            local i=1
            for s in "${SOLUTIONS[@]}"; do
                echo "  $i) $s"; i=$((i+1))
            done
            local pick
            read -r -p "Pick number or name: " pick
            if [[ "$pick" =~ ^[0-9]+$ ]]; then
                if [ "$pick" -lt 1 ] || [ "$pick" -gt "${#SOLUTIONS[@]}" ]; then
                    die "Pick must be between 1 and ${#SOLUTIONS[@]}: got '$pick'"
                fi
                solution="${SOLUTIONS[$((pick-1))]}"
            else
                solution="$pick"
            fi
        fi
    fi

    info "${BOLD}Solution up: $name / $solution${RST}"
    cd_repo_root "$REPO"
    local actual_env
    actual_env=$(confirm_pac_profile "$PROFILE")

    local unpack_dir="$SCHEMA_DIR/$solution"
    [ -d "$unpack_dir" ] || die "$unpack_dir does not exist. Did you run pp solution-down first?"

    warn "Solution import is DESTRUCTIVE — overwrites schema in target env."
    confirm_action "Confirm import '$solution' to $actual_env ?"

    case "$actual_env" in
        *prod*)
            warn "${BOLD}PRODUCTION ENVIRONMENT${RST}"
            local ans
            read -r -p "Type the solution name '$solution' to confirm: " ans
            [ "$ans" = "$solution" ] || die "Aborted."
            ;;
    esac

    local zipfile="$SCHEMA_DIR/${solution}.zip"
    info "Packing…"
    pac solution pack --folder "$unpack_dir" --zipfile "$zipfile" --packagetype Unmanaged || die "Pack failed"

    info "Importing… (may take several minutes)"
    pac solution import --path "$zipfile" --publish-changes --activate-plugins || die "Import failed"

    rm -f "$zipfile"
    ok "Done."
}

# ===========================================================================
# Subcommand: audit (delegates to pp-permissions-audit)
# ===========================================================================

cmd_audit() {
    local input="${1:-}"
    shift || true
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"

    cd_repo_root "$REPO"

    # Find audit.py — prefer installed plugin cache, fall back to this repo checkout
    local audit_py
    audit_py=$(find \
        "$HOME/.claude/plugins/cache/nq-claude-power-pages-plugins/pp-permissions-audit" \
        "$HOME/.claude/plugins/cache/nq-claude-plugins/pp-permissions-audit" \
        -name "audit.py" 2>/dev/null | sort -V | tail -1)
    if [ -z "$audit_py" ] && [ -f "$REPO/plugins/pp-permissions-audit/skills/pp-permissions-audit/scripts/audit.py" ]; then
        audit_py="$REPO/plugins/pp-permissions-audit/skills/pp-permissions-audit/scripts/audit.py"
    fi
    [ -n "$audit_py" ] || die "pp-permissions-audit plugin not installed and repo-local audit.py not found"

    info "${BOLD}Audit: $name${RST}"
    info "Site:  $SITE_DIR"
    python3 "$audit_py" "$SITE_DIR" "$@"
}

# ===========================================================================
# Subcommand: sync-pages (copy base ↔ localized files in bulk)
# ===========================================================================

cmd_sync_pages() {
    local input="${1:-}"
    local direction="${2:-}"
    shift 2 2>/dev/null || true

    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"
    cd_repo_root "$REPO"

    [ -d "$SITE_DIR/web-pages" ] || die "$SITE_DIR/web-pages does not exist"

    # Pick direction
    if [ -z "$direction" ]; then
        echo "Power Pages stores web-page assets in TWO places per page:"
        echo "  base:      <slug>/<Page>.webpage.copy.html"
        echo "  localized: <slug>/content-pages/<lang>/<Page>.<lang>.webpage.copy.html"
        echo
        echo "Sync direction options:"
        echo "  1) base   → localized   (copy base file content into all locale variants)"
        echo "  2) localized → base     (copy first locale variant into the base)"
        read -r -p "Pick (1/2): " choice
        case "$choice" in
            1) direction="base-to-localized" ;;
            2) direction="localized-to-base" ;;
            *) die "Invalid choice" ;;
        esac
    fi

    info "${BOLD}Sync pages: $name${RST}  (direction: $direction)"

    local copied=0 skipped=0
    local suffixes=(
        ".webpage.copy.html"
        ".webpage.custom_javascript.js"
        ".webpage.custom_css.css"
        ".webpage.summary.html"
    )

    for page_dir in "$SITE_DIR"/web-pages/*/; do
        [ -d "$page_dir" ] || continue
        local cp_dir="${page_dir}content-pages"
        [ -d "$cp_dir" ] || continue

        for suffix in "${suffixes[@]}"; do
            # Find base file (non-locale-prefixed)
            local base_file=""
            for f in "$page_dir"*"$suffix"; do
                [ -f "$f" ] || continue
                # Skip files in content-pages subdirectory
                [[ "$f" == *"/content-pages/"* ]] && continue
                base_file="$f"
                break
            done
            [ -z "$base_file" ] && continue

            # Find first localized file
            local loc_file=""
            for f in "$cp_dir"/*"$suffix"; do
                [ -f "$f" ] || continue
                loc_file="$f"
                break
            done
            [ -z "$loc_file" ] && continue

            case "$direction" in
                base-to-localized)
                    # Copy base content into ALL localized variants
                    for f in "$cp_dir"/*"$suffix"; do
                        [ -f "$f" ] || continue
                        if cmp -s "$base_file" "$f"; then
                            skipped=$((skipped + 1))
                        else
                            cp "$base_file" "$f"
                            copied=$((copied + 1))
                            echo "  base → $(basename "$f")"
                        fi
                    done
                    ;;
                localized-to-base)
                    if cmp -s "$loc_file" "$base_file"; then
                        skipped=$((skipped + 1))
                    else
                        cp "$loc_file" "$base_file"
                        copied=$((copied + 1))
                        echo "  $(basename "$loc_file") → base"
                    fi
                    ;;
            esac
        done
    done

    echo
    ok "Copied: $copied  ·  Already in sync: $skipped"
    info "Review with: git diff --stat $SITE_DIR/web-pages"
    info "Then commit and run: pp up $name"
}

# ===========================================================================
# Subcommand: generate-page
# ===========================================================================

cmd_generate_page() {
    local input="${1:-}"
    local page_name="${2:-}"
    if [ -z "$input" ] || [ -z "$page_name" ]; then
        die "Usage: pp generate-page <project> <Page-Name>"
    fi

    # Validate page_name before it flows into filenames + heredocs.
    # Allows letters, numbers, spaces, dashes, underscores, dots — but
    # rejects shell metacharacters AND path-traversal sequences (`..`,
    # `/`, `\\`) that could escape the page directory.
    validate_identifier "Page name" "$page_name" '^[A-Za-z0-9 _.-]+$'
    case "$page_name" in
        *..*|*/*|*\\*) die "Page name may not contain '..', '/', or backslash: '$page_name'" ;;
    esac

    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    load_project "$name"
    cd_repo_root "$REPO"

    # Clean the name for folders/filenames: "My Awesome Page" -> "my-awesome-page"
    local slug
    slug=$(echo "$page_name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g; s/--*/-/g; s/^-//; s/-$//')
    
    local page_dir="$SITE_DIR/web-pages/$slug"
    [ -d "$page_dir" ] && die "Page folder already exists: $page_dir"

    info "Generating page: $page_name ($slug)"
    mkdir -p "$page_dir/content-pages"

    # 1. Base Metadata (.webpage.yml)
    # We use some heuristics to guess valid references
    local website_id_val="${WEBSITE_ID:-00000000-0000-0000-0000-000000000000}"
    # Pick the first page template we find, or use a placeholder
    local template_name
    template_name=$(find "$SITE_DIR/page-templates" -name "*.pagetemplate.yml" -maxdepth 1 2>/dev/null | head -1 | sed 's/.*\///; s/\.pagetemplate\.yml//')
    template_name="${template_name:-Full Page}"

    cat > "$page_dir/$page_name.webpage.yml" <<EOF
adx_name: $page_name
adx_partialurl: $slug
adx_pagetemplateid: $template_name
adx_publishingstateid: Published
adx_websiteid: $website_id_val
EOF

    # 2. Base HTML
    cat > "$page_dir/$page_name.webpage.copy.html" <<EOF
<!-- $page_name (Base) -->
<div class="container">
  <div class="row">
    <div class="col-md-12">
      <h1>$page_name</h1>
      <p>This is a new hybrid-pattern Power Pages page.</p>
    </div>
  </div>
</div>
EOF

    # 3. Base JS
    cat > "$page_dir/$page_name.webpage.custom_javascript.js" <<'EOF'
(function($) {
  $(function() {
    console.log("Page initialized");
    // window.shell.getTokenDeferred().done(function(token) { ... });
  });
})(window.jQuery);
EOF

    # 4. Base CSS
    cat > "$page_dir/$page_name.webpage.custom_css.css" <<EOF
/* $page_name styles */
.section-$slug {
  padding: 20px 0;
}
EOF

    # 5. Localized Content (en-US default)
    local loc_prefix="$page_dir/content-pages/$page_name.en-US"
    cp "$page_dir/$page_name.webpage.copy.html" "$loc_prefix.webpage.copy.html"
    cp "$page_dir/$page_name.webpage.custom_javascript.js" "$loc_prefix.webpage.custom_javascript.js"

    ok "Page scaffolded in $page_dir"
    info "Hybrid-pattern files generated (base + en-US localized)."
}

# ===========================================================================
# Subcommand: journal (automated work tracking)
# ===========================================================================

cmd_journal() {
    local input="${1:-}"
    local action="${2:-}"
    shift 2 2>/dev/null || true
    
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    export PP_REQUIRE_BOARD_CONFIRM=1
    load_project "$name"
    unset PP_REQUIRE_BOARD_CONFIRM
    cd_repo_root "$REPO"
    
    # Check for gh/glab
    local has_gh=0 has_glab=0
    command -v gh >/dev/null 2>&1 && has_gh=1
    command -v glab >/dev/null 2>&1 && has_glab=1

    local board_mode="${BOARD_SYSTEM:-auto}"
    if [ "$board_mode" = "auto" ]; then
        case "${BOARD_URL:-}" in
            *github.com*|github:*) board_mode="github" ;;
            *gitlab.com*|gitlab:*) board_mode="gitlab" ;;
            "") board_mode="none" ;;
            *) board_mode="none" ;;
        esac
    fi

    case "$action" in
        init)
            info "Initializing journal for $name"
            [ -f "$REPO/JOURNAL.md" ] || {
                cat > "$REPO/JOURNAL.md" <<EOF
# Work Journal: $NAME
This file tracks tasks, technical reasoning, and audit findings for the dev team.

## Project Context
- **Board Mapping**: ${BOARD_URL:-"(none)"}
- **System**: ${BOARD_SYSTEM:-"auto"}
- **AI Attribution**: ${AI_ATTR:-"yes"}
EOF
                ok "Created $REPO/JOURNAL.md"
            }
            ;;
        
        open)
            local title="${1:-}"
            [ -z "$title" ] && die "Usage: pp journal open <title>"
            info "Opening task: $title"
            
            local issue_url=""
            if [ "$board_mode" = "github" ] && [ "$has_gh" = "1" ]; then
                # Filter to just the issue URL — older `gh` versions and
                # some non-TTY contexts emit informational lines to stdout
                # alongside the URL. Mirrors the gitlab branch.
                issue_url=$(gh issue create --title "$title" --body "Task initiated via pp-sync journal." --label "automated-journal" 2>/dev/null \
                    | grep -oE 'https://github\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[0-9]+' | head -1 || true)
            elif [ "$board_mode" = "gitlab" ] && [ "$has_glab" = "1" ]; then
                issue_url=$(glab issue create --title "$title" --description "Task initiated via pp-sync journal." 2>/dev/null \
                    | grep -oE 'https://gitlab\.com/[A-Za-z0-9_./-]+/issues/[0-9]+' | head -1 || true)
            fi

            # Defense in depth: even though gh/glab created this URL on
            # the user's authenticated repo, validate before persisting
            # to JOURNAL.md so a misconfigured CLI default-repo cannot
            # silently seed a cross-repo URL into the journal.
            if [ -n "$issue_url" ]; then
                validate_issue_url_for_current_repo "$issue_url"
            fi

            {
                echo ""
                echo "## [$(date +'%Y-%m-%d %H:%M')] TASK: $title"
                [ -n "$issue_url" ] && echo "Issue: $issue_url"
                echo "---"
            } >> "$REPO/JOURNAL.md"
            
            [ -n "$issue_url" ] && ok "Opened issue: $issue_url" || ok "Started local journal entry."
            ;;

        note)
            local msg="${1:-}"
            [ -z "$msg" ] && die "Usage: pp journal note <message>"
            local attr=""
            [ "${AI_ATTR:-yes}" = "yes" ] && attr=" [AI-Assisted]"

            # Find the URL written by the most recent `pp journal open`.
            # Specifically match `^Issue: https://...` lines that the open
            # subcommand writes — NOT arbitrary URLs that may appear in
            # user notes (e.g. "see also https://other/repo/issues/5").
            # This prevents lockout: a single inline cross-repo reference
            # in a note used to make subsequent `note`/`close` permanently
            # refuse to operate.
            local last_issue=""
            if [ -f "$REPO/JOURNAL.md" ]; then
                last_issue=$(grep -E '^Issue: https://(github|gitlab)\.com/' "$REPO/JOURNAL.md" \
                    | tail -1 | sed 's/^Issue: //' || true)
            fi
            if [ -n "$last_issue" ]; then
                validate_issue_url_for_current_repo "$last_issue"
            fi

            info "Adding note..."
            echo "- **Note$attr**: $msg" >> "$REPO/JOURNAL.md"

            if [ -n "$last_issue" ]; then
                if [[ "$last_issue" == *"github.com"* ]] && [ "$has_gh" = "1" ]; then
                    gh issue comment "$last_issue" --body "$msg$attr" >/dev/null 2>&1 \
                        || warn "Failed to post comment to $last_issue"
                elif [[ "$last_issue" == *"gitlab.com"* ]] && [ "$has_glab" = "1" ]; then
                    glab issue note "$last_issue" --message "$msg$attr" >/dev/null 2>&1 \
                        || warn "Failed to post note to $last_issue"
                fi
            fi
            ;;

        close)
            local summary="${1:-}"

            # Same as `note`: only consider URLs written by `pp journal
            # open` (lines beginning with `Issue: `), not arbitrary URLs
            # in user-authored notes.
            local last_issue=""
            if [ -f "$REPO/JOURNAL.md" ]; then
                last_issue=$(grep -E '^Issue: https://(github|gitlab)\.com/' "$REPO/JOURNAL.md" \
                    | tail -1 | sed 's/^Issue: //' || true)
            fi
            if [ -n "$last_issue" ]; then
                validate_issue_url_for_current_repo "$last_issue"
            fi

            info "Closing task..."
            echo "- **CLOSED**: $summary" >> "$REPO/JOURNAL.md"

            if [ -n "$last_issue" ]; then
                if [[ "$last_issue" == *"github.com"* ]] && [ "$has_gh" = "1" ]; then
                    gh issue comment "$last_issue" --body "Task closed: $summary" >/dev/null 2>&1 \
                        || warn "Failed to post close comment to $last_issue"
                    gh issue close "$last_issue" >/dev/null 2>&1 \
                        || warn "Failed to close $last_issue"
                elif [[ "$last_issue" == *"gitlab.com"* ]] && [ "$has_glab" = "1" ]; then
                    glab issue note "$last_issue" --message "Task closed: $summary" >/dev/null 2>&1 \
                        || warn "Failed to post close note to $last_issue"
                    glab issue close "$last_issue" >/dev/null 2>&1 \
                        || warn "Failed to close $last_issue"
                fi
                ok "Closed issue $last_issue"
            fi
            ;;
        *)
            die "Usage: pp journal {init|open|note|close}"
            ;;
    esac
}

cmd_project_add() {
    ensure_config_dirs
    local name="${1:-}"
    [ -z "$name" ] && { read -r -p "Project name: " name; }
    [ -z "$name" ] && die "Project name required"
    validate_identifier "Project name" "$name" '^[A-Za-z0-9_-]+$'
    [ -f "$PP_PROJECTS_DIR/$name.conf" ] && die "$name already exists. Use 'pp project edit' or remove first."

    local repo site_dir profile website_id env_url solutions branch board_url board_system ai_attr
    read -r -p "Repo path:       " repo
    read -r -p "Site folder (relative): " site_dir
    read -r -p "PAC profile:     " profile
    [ -n "$profile" ] && validate_identifier "PAC profile" "$profile" '^[A-Za-z0-9_.-]+$'
    read -r -p "Website ID:      " website_id
    read -r -p "Env URL:         " env_url
    read -r -p "Solutions (comma-separated): " solutions
    read -r -p "Default branch:  " branch
    read -r -p "Project board URL/ID: " board_url
    read -r -p "Board system (github/gitlab/none): " board_system
    read -r -p "Tag AI notes? [y/n]: " ai_attr

    local alias_input
    read -r -p "Add an alias? (blank = none): " alias_input

    # Validate everything BEFORE creating the conf so registration is atomic.
    # If solutions or alias fail validation, no file is touched.
    local solutions_block=""
    if [ -n "$solutions" ]; then
        solutions_block=$(format_solutions_array "$solutions")
    fi
    if [ -n "$alias_input" ]; then
        validate_identifier "Alias" "$alias_input" '^[A-Za-z0-9_-]+$'
    fi

    cat > "$PP_PROJECTS_DIR/$name.conf" <<EOF
# $name — created by 'pp project add'
NAME="$name"
REPO="$repo"
SITE_DIR="$site_dir"
PROFILE="$profile"
WEBSITE_ID="$website_id"
ENV_URL="$env_url"
MODEL_VERSION="2"
SCHEMA_DIR="dataverse-schema"
BRANCH="$branch"
BOARD_URL="$board_url"
BOARD_SYSTEM="$board_system"
AI_ATTR="$ai_attr"
TAGS=""
EOF
    [ -n "$solutions_block" ] && printf '%s' "$solutions_block" >> "$PP_PROJECTS_DIR/$name.conf"
    ok "Registered $name"

    if [ -n "$alias_input" ]; then
        echo "${alias_input}=${name}" >> "$PP_ALIASES_FILE"
        ok "Alias: pp <op> $alias_input"
    fi
}

cmd_project_remove() {
    local input="${1:-}"
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    confirm_action "Remove $name?"
    rm -f "$PP_PROJECTS_DIR/$name.conf"
    # Remove aliases that point to this project
    if [ -f "$PP_ALIASES_FILE" ]; then
        sed -i.bak "/=${name}\$/d" "$PP_ALIASES_FILE" 2>/dev/null \
            || sed -i '' "/=${name}\$/d" "$PP_ALIASES_FILE"
        rm -f "${PP_ALIASES_FILE}.bak"
    fi
    [ -f "$PP_ACTIVE_FILE" ] && [ "$(cat "$PP_ACTIVE_FILE")" = "$name" ] && rm -f "$PP_ACTIVE_FILE"
    ok "Removed $name"
}

cmd_project_edit() {
    local input="${1:-}"
    local name
    name=$(resolve_project "$input") || die "Unknown project: $input"
    "${EDITOR:-vi}" "$PP_PROJECTS_DIR/$name.conf"
}

cmd_alias_add() {
    ensure_config_dirs
    local alias_name="${1:-}"
    local target="${2:-}"
    if [ -z "$alias_name" ] || [ -z "$target" ]; then
        die "Usage: pp alias add <alias> <project>"
    fi
    validate_identifier "Alias" "$alias_name" '^[A-Za-z0-9_-]+$'
    local resolved
    resolved=$(resolve_project "$target") || die "Unknown target: $target"
    if grep -qE "^${alias_name}=" "$PP_ALIASES_FILE" 2>/dev/null; then
        sed -i.bak "/^${alias_name}=/d" "$PP_ALIASES_FILE" 2>/dev/null \
            || sed -i '' "/^${alias_name}=/d" "$PP_ALIASES_FILE"
        rm -f "${PP_ALIASES_FILE}.bak"
    fi
    echo "${alias_name}=${resolved}" >> "$PP_ALIASES_FILE"
    ok "Alias added: $alias_name -> $resolved"
}

cmd_alias_list() {
    ensure_config_dirs
    [ -s "$PP_ALIASES_FILE" ] || { info "No aliases registered."; return; }
    column -t -s= "$PP_ALIASES_FILE"
}

# ===========================================================================
# Subcommand: help
# ===========================================================================

cmd_help() {
    cat <<'EOF'
pp — Power Pages CLI dispatcher

USAGE
    pp <command> [project] [options]

PROJECT REGISTRY
    pp setup                       Interactive bootstrap (auto-detect projects + PAC profiles)
    pp list                        List all registered projects
    pp show <project>              Show details for a project
    pp project add [name]          Register a new project
    pp project edit <project>      Edit a project's config in $EDITOR
    pp project remove <project>    Remove a project (and its aliases)
    pp alias add <alias> <project> Add a shorthand alias for a project
    pp alias list                  List all aliases

ENV / PROJECT SWITCHING
    pp switch <project>            Set as the active project (also pac auth select)
    pp status                      Show currently active project + live env

SYNC OPERATIONS  (project arg required, alias OK)
    pp down <project> [--no-clean]
    pp up   <project> [--validate-only] [--force-bulk] [--bulk-threshold=N]
    pp diff <project> [--diff] [--names-only] [--bulk-threshold=N]
    pp doctor <project>
    pp generate-page <project> <Name>
    pp journal <project> {init|open|note|close} <args>
    pp solution-down <project> [solution]
    pp solution-up   <project> [solution]
    pp sync-pages    <project> [base-to-localized|localized-to-base]
    pp audit <project> [--severity ERROR|WARN|INFO] [--exit-code] [--json]

PROJECT NAME RESOLUTION
    Order:  exact match  >  alias  >  unique prefix
    "acm"    resolves to "acme-dev"     if no other "acm*" projects exist
    "ac"     resolves via alias if you set one with `pp alias add ac acme-dev`

EXAMPLES
    pp setup
    pp list
    pp down acme                   # exact match
    pp up ac                       # alias resolution
    pp audit acme --severity ERROR --exit-code     # CI-friendly
    pp solution-down acme MyAcmeSolution
    pp switch acme-client
    pp status

CONFIG LOCATION
    $HOME/.config/nq-pp-sync/projects/<name>.conf   per-project config (sourced bash)
    $HOME/.config/nq-pp-sync/aliases                alias=target  one per line
    $HOME/.config/nq-pp-sync/active                 currently active project name
EOF
}

# ===========================================================================
# Dispatch
# ===========================================================================

main() {
    set -euo pipefail
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        setup)         cmd_setup "$@" ;;
        list|ls)       cmd_list "$@" ;;
        show)          cmd_show "$@" ;;
        switch|use)    cmd_switch "$@" ;;
        status)        cmd_status "$@" ;;
        down|d)        cmd_down "$@" ;;
        up|u)          cmd_up "$@" ;;
        diff)          cmd_diff "$@" ;;
        doctor)        cmd_doctor "$@" ;;
        generate-page|gen-page) cmd_generate_page "$@" ;;
        journal)       cmd_journal "$@" ;;
        commit)        die "Use git directly or copy templates/commit.sh — pp commit not yet implemented in CLI" ;;
        solution-down|sol-down) cmd_solution_down "$@" ;;
        solution-up|sol-up)     cmd_solution_up "$@" ;;
        sync-pages)    cmd_sync_pages "$@" ;;
        audit)         cmd_audit "$@" ;;
        project)
            local sub="${1:-}"; shift || true
            case "$sub" in
                add)    cmd_project_add "$@" ;;
                edit)   cmd_project_edit "$@" ;;
                remove|rm) cmd_project_remove "$@" ;;
                list|ls) cmd_list "$@" ;;
                *) die "Usage: pp project {add|edit|remove|list}" ;;
            esac
            ;;
        alias)
            local sub="${1:-}"; shift || true
            case "$sub" in
                add)    cmd_alias_add "$@" ;;
                list|ls) cmd_alias_list "$@" ;;
                *) die "Usage: pp alias {add|list}" ;;
            esac
            ;;
        help|-h|--help) cmd_help ;;
        *) err "Unknown command: $cmd"; cmd_help; exit 2 ;;
    esac
}

# Source-safe guard: when this file is sourced (e.g. by tests), `return`
# succeeds and we skip dispatching. When executed as a script, `return`
# errors and main runs. Allows the bash test suite to load helpers and
# load_project() in isolation.
return 2>/dev/null || main "$@"
